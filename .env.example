# PulseFit Database Configuration - EXAMPLE
# Copy this file to .env and fill in your actual values
# .env is ignored by git and should NEVER be committed

# Database Host (IP address or hostname)
DB_HOST=localhost

# Database Port (default MySQL/MariaDB: 3306)
DB_PORT=3306

# Database Username
DB_USER=pulsefit_user

# Database Password
DB_PASS=your_secure_password_here

# Database Name
DB_NAME=pulsefit_db
